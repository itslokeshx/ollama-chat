{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ollama Chat",
  "version": "1.0.0",
  "identifier": "com.ollama.chat",
  "build": {
    "frontendDist": "../dist/public",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Ollama Chat",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "curl", "libgtk-3-0"]
      }
    }
  }
}
